# Base URL of the backend API.
# Leave EMPTY in development: requests go to "/api" and are proxied by Vite
# to the backend (see vite.config.ts). Set to the deployed backend URL in prod,
# e.g. https://api.denis-kim.dev
VITE_API_BASE_URL=

# Optional: override the dev proxy target (defaults to http://localhost:3001)
VITE_DEV_API_TARGET=http://localhost:3001

# Captcha site key (public). Provider is selected on the server.
# Leave empty for the development placeholder captcha.
VITE_CAPTCHA_SITE_KEY=
